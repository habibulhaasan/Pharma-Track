// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    function isActiveUser() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active';
    }

    function isOwnDocument(userId) {
      return request.auth.uid == userId;
    }

    // ─── Users ─────────────────────────────────────────────────────────
    // Users can read their own doc; admins can read all
    // Creation happens via Admin SDK (server-only) after Firebase Auth registration
    // Status updates (approve/disable) only via Admin SDK
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwnDocument(userId) || isAdmin());
      allow create: if false; // Server-only via Admin SDK
      allow update: if false; // Server-only via Admin SDK
      allow delete: if false; // Never delete users
    }

    // ─── Products ──────────────────────────────────────────────────────
    // All active users can read; only admins can write (via Admin SDK)
    match /products/{productId} {
      allow read: if isActiveUser();
      allow write: if false; // Server-only via Admin SDK
    }

    // ─── Main Stock ────────────────────────────────────────────────────
    // Active users can READ stock levels for UI display
    // ALL WRITES must go through server actions / Admin SDK (transactions)
    match /mainStock/{productId} {
      allow read: if isActiveUser();
      allow write: if false; // Server-only — enforced via Admin SDK transactions
    }

    match /mainStock/{productId}/mainLedger/{ledgerId} {
      allow read: if isActiveUser();
      allow write: if false; // Server-only
    }

    // ─── Pharmacy Stock ────────────────────────────────────────────────
    match /pharmacyStock/{productId} {
      allow read: if isActiveUser();
      allow write: if false; // Server-only
    }

    match /pharmacyStock/{productId}/pharmacyLedger/{ledgerId} {
      allow read: if isActiveUser();
      allow write: if false; // Server-only
    }

    // ─── Sales ─────────────────────────────────────────────────────────
    match /sales/{saleId} {
      allow read: if isActiveUser();
      allow write: if false; // Server-only
    }

    // ─── Activity Log ──────────────────────────────────────────────────
    // Admins can read; nobody can write from client
    match /activityLog/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Server-only
    }

    // ─── Deny all other paths ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
